mport random as ran
i = 1
num = ran.randint(1,20)
while i<3:
    a = int(input("Guess a number between 1 to 20: "))
    if a > num:
        print("Try to guess a smaller number")
    elif a < num:
        print("Try to guess a larger number")  
    elif a == num:
        print("You Guessed it right!!")
        break
    else:
        print("Enter the value right")
    i +=1

while i == 3:
